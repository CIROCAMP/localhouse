{
  "buildCommand": "npx vite build",
  "outputDirectory": "dist/public",
  "redirects": [
    { "source": "/menu/dinner/:path*", "destination": "/restaurant", "permanent": true },
    { "source": "/menu/happy-hour/:path*", "destination": "/restaurant", "permanent": true },
    { "source": "/menu/miami-spice/:path*", "destination": "/restaurant", "permanent": true },
    { "source": "/menu/brunch/:path*", "destination": "/restaurant", "permanent": true },
    { "source": "/menu/drinks/:path*", "destination": "/restaurant", "permanent": true },
    { "source": "/menu/dessert/:path*", "destination": "/restaurant", "permanent": true },
    { "source": "/menu/:path*", "destination": "/restaurant", "permanent": true },
    { "source": "/menus/:path*", "destination": "/restaurant", "permanent": true },
    { "source": "/event/august-3rd-music-brunch/:path*", "destination": "/brunch", "permanent": true },
    { "source": "/event/private-balconies/:path*", "destination": "/private-events", "permanent": true },
    { "source": "/event/:path*", "destination": "/private-events", "permanent": true },
    { "source": "/explore-2/:path*", "destination": "/", "permanent": true },
    { "source": "/explore/:path*", "destination": "/", "permanent": true },
    { "source": "/advanced/:path*", "destination": "/", "permanent": true },
    { "source": "/it", "destination": "/", "permanent": true },
    { "source": "/sleep/:path*", "destination": "/hotel", "permanent": true },
    { "source": "/about/:path*", "destination": "/culture", "permanent": true },
    { "source": "/offers-gallery/:path*", "destination": "/gallery", "permanent": true },
    { "source": "/offers/:path*", "destination": "/", "permanent": true },
    { "source": "/store/cart/:path*", "destination": "/", "permanent": true },
    { "source": "/terms-and-conditions/:path*", "destination": "/", "permanent": true },
    { "source": "/the-local-house-team/:path*", "destination": "/culture", "permanent": true },
    { "source": "/location/hours-location/:path*", "destination": "/contact", "permanent": true },
    {
      "source": "/:path(.*)",
      "has": [{ "type": "host", "value": "localhouse.com" }],
      "destination": "https://www.localhouse.com/:path",
      "permanent": true
    }
  ],
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
